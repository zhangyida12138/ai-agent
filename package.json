{
  "name": "ai-agent",
  "description": "LieFree（无谎空间）— Local brain, no lies.",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "base": "./",
  "scripts": {
    "dev": "pnpm --parallel --filter @ai-agent/sidecar --filter @ai-agent/desktop run dev",
    "dev:sidecar": "pnpm --filter @ai-agent/sidecar dev",
    "dev:desktop": "pnpm --filter @ai-agent/desktop dev",
    "start": "pnpm run start:sidecar",
    "start:sidecar": "pnpm --filter @ai-agent/sidecar start",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3"
  }
}
