{
  "name": "ai-agent",
  "description": "LieFree（无谎空间）— Local brain, no lies.",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "base": "./",
  "scripts": {
    "dev": "pnpm --parallel --filter @ai-agent/sidecar --filter @ai-agent/desktop run dev",
    "dev:sidecar": "pnpm --filter @ai-agent/sidecar dev",
    "dev:desktop": "pnpm --filter @ai-agent/desktop dev",
    "start": "pnpm run start:sidecar",
    "start:sidecar": "pnpm --filter @ai-agent/sidecar start",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck"
  }
}

