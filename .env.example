# --- Sidecar AI（LangChain，智谱优先）---
# 主路与备用（默认 zhipu → 失败切 deepseek，链上还可尝试 gemini）
AI_PRIMARY_PROVIDER=zhipu
AI_FALLBACK_PROVIDER=deepseek
AI_PROVIDER_KIND=zhipu

ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash
ZHIPU_EMBEDDING_MODEL=embedding-3

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=text-embedding-3-small

GEMINI_API_KEY=
# 也可使用 GOOGLE_API_KEY（GEMINI_API_KEY 优先）
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# Gemini OpenAI 兼容基址（Page Agent 转发 Gemini 时使用）
# GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# 国内访问 Google API 时：
# HTTPS_PROXY=http://127.0.0.1:7890

# Page Agent 上游顺序（OpenAI 兼容代理）
PAGE_AGENT_FAILOVER_ORDER=zhipu,gemini,deepseek

# --- 前端构建 ---
VITE_SIDECAR_URL=http://localhost:3001
# Page Agent 默认模型名（须与主路上游一致，如 glm-4-flash）
# VITE_PAGE_AGENT_MODEL=glm-4-flash

# --- Sidecar 服务 ---
SIDECAR_PORT=3001
CORS_ORIGINS=http://localhost:5173
SIDECAR_BODY_LIMIT=32mb
# 主路/备用模型单次请求超时（毫秒）；备用默认 25s，避免 Gemini 不可达时前端一直转圈
AI_PROVIDER_TIMEOUT_MS=60000
AI_FALLBACK_TIMEOUT_MS=25000
