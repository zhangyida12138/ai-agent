# =============================================================================
# AI Agent 环境变量模板（仓库根目录）
#
# 使用方式：
#   cp .env.example .env          # 本地开发
#   cp .env.example .env.production  # 生产（勿提交，已在 .gitignore）
#
# Sidecar 加载顺序：
#   .env → .env.local → .env.[development|production] → .env.[mode].local
# 已在进程中的非空变量不会被文件里的空值覆盖（便于 systemd 注入密钥）。
# =============================================================================

# -----------------------------------------------------------------------------
# 运行环境
# -----------------------------------------------------------------------------
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Sidecar 服务
# -----------------------------------------------------------------------------
SIDECAR_PORT=3001
SIDECAR_BODY_LIMIT=32mb
# SIDECAR_PORT_STRATEGY=lock
# SIDECAR_PORT_MAX_TRIES=20
SQLITE_PATH=./data/ai-agent.sqlite
TRUST_PROXY=0

# 浏览器 Origin（生产须写完整 https 域名，apex 与 www 都要列）
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# 前端构建（Vite：仅 VITE_ 前缀会打进静态包）
# -----------------------------------------------------------------------------
# 开发：直连 Sidecar
VITE_SIDECAR_URL=http://localhost:3001
# 生产：与 Nginx 同域反代
# VITE_SIDECAR_URL=/api

VITE_PAGE_AGENT_MODEL=qwen-plus
# VITE_PAGE_AGENT_LANGUAGE=zh-CN

# -----------------------------------------------------------------------------
# AI 路由（主聊天 / RAG 嵌入）
# -----------------------------------------------------------------------------
# 故障转移顺序（推荐，覆盖下面 PRIMARY/FALLBACK）
AI_FAILOVER_ORDER=zhipu,qwen,deepseek,gemini
# 请求中「优先尝试」的提供商（会插在 AI_FAILOVER_ORDER 最前）
AI_PRIMARY_PROVIDER=zhipu
AI_PROVIDER_KIND=zhipu

AI_PROVIDER_TIMEOUT_MS=60000
AI_FALLBACK_TIMEOUT_MS=25000

# -----------------------------------------------------------------------------
# 智谱 Zhipu（https://open.bigmodel.cn/usercenter/apikeys）
# -----------------------------------------------------------------------------
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash
ZHIPU_EMBEDDING_MODEL=embedding-3

# -----------------------------------------------------------------------------
# 千问 Qwen / 通义 DashScope（Key: https://bailian.console.aliyun.com/?tab=model#/api-key）
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=
# 别名：QWEN_API_KEY=
# 国内（北京）：
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 国际账号改用：
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# -----------------------------------------------------------------------------
# DeepSeek（https://platform.deepseek.com/）
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Gemini（https://aistudio.google.com/apikey）
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
# GEMINI_BASE_URL=
# GEMINI_API_VERSION=v1beta
# GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_CONNECT_PROBE_MS=12000

# -----------------------------------------------------------------------------
# 出站代理（国内访问 Google 时常用；改后重启 Sidecar）
# -----------------------------------------------------------------------------
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=

# -----------------------------------------------------------------------------
# Page Agent（浏览器自动化；默认千问 + tools）
# -----------------------------------------------------------------------------
PAGE_AGENT_FAILOVER_ORDER=qwen,zhipu,deepseek,gemini
# 仅千问；智谱/Gemini 请用 PAGE_AGENT_ZHIPU_MODEL 等，勿写进 PAGE_AGENT_MODEL
PAGE_AGENT_MODEL=qwen-plus
PAGE_AGENT_QWEN_MODEL=qwen-plus
PAGE_AGENT_ZHIPU_MODEL=glm-4-plus
# 账号支持时：PAGE_AGENT_QWEN_MODEL=qwen3-max
# PAGE_AGENT_GEMINI_MODEL=gemini-2.0-flash
# PAGE_AGENT_DEEPSEEK_MODEL=deepseek-chat
# 仅千问单上游：PAGE_AGENT_UPSTREAM=qwen
# PAGE_AGENT_LOG_MODEL=1

# -----------------------------------------------------------------------------
# RAG 本地知识库
# -----------------------------------------------------------------------------
RAG_SCORE_THRESHOLD=0.08
RAG_RERANK_WEIGHT=0.65
