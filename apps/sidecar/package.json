{
  "name": "@ai-agent/sidecar",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "predev": "pnpm --filter @ai-agent/shared build",
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "cross-env NODE_ENV=production node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(skip)\"",
    "check:gemini": "node scripts/check-gemini-network.mjs",
    "check:qwen": "node scripts/check-dashscope.mjs"
  },
  "dependencies": {
    "@ai-agent/shared": "workspace:*",
    "@langchain/core": "^1.1.47",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/openai": "^1.4.6",
    "@nestjs/common": "*",
    "@nestjs/core": "*",
    "@nestjs/platform-express": "*",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.0",
    "reflect-metadata": "*",
    "rxjs": "*",
    "sql.js": "*",
    "undici": "^6.21.3"
  },
  "devDependencies": {
    "@types/express": "*",
    "@types/node": "*",
    "tsx": "*",
    "typescript": "*"
  }
}
