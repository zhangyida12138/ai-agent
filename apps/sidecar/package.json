{
  "name": "@ai-agent/sidecar",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "predev": "pnpm --filter @ai-agent/shared build",
    "dev": "cross-env NODE_ENV=development tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "cross-env NODE_ENV=production node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(skip)\""
  },
  "dependencies": {
    "@ai-agent/shared": "workspace:*",
    "@nestjs/common": "*",
    "@nestjs/core": "*",
    "@nestjs/platform-express": "*",
    "dotenv": "^17.4.0",
    "reflect-metadata": "*",
    "rxjs": "*",
    "sql.js": "*"
  },
  "devDependencies": {
    "@types/express": "*",
    "@types/node": "*",
    "cross-env": "^7.0.3",
    "tsx": "*",
    "typescript": "*"
  }
}
